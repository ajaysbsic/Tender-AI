# Backend Environment Configuration
# Copy to .env and update values

# Application
DEBUG=True
APP_NAME=TenderIQ
APP_VERSION=1.0.0

# Database
DATABASE_URL=sqlite:///./tenderiq.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/tenderiq

# Authentication
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Document Processing
MAX_FILE_SIZE_MB=500
UPLOAD_DIR=uploads
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# Vector Store
FAISS_INDEX_PATH=faiss_indices

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:4200"]

# LLM Configuration (TO BE CONFIGURED WHEN AI LOGIC IS IMPLEMENTED)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-api-key
# LLM_MODEL=gpt-4
